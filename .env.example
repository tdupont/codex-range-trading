# App
APP_ENV=development
APP_NAME=range-trading-screener
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Storage
DATABASE_URL=sqlite:///data/range_trading.db

# Universe and scan configuration
MARKET_UNIVERSE=sp500
DEFAULT_TIMEFRAME=1d
SUPPORTED_SCAN_TIMEFRAMES=1d,1wk,1mo
SCAN_LOOKBACK_BARS=180
RANGE_LOOKBACK_BARS=30

# Indicator configuration
ADX_PERIOD=14
SMA_PERIOD=20
ATR_PERIOD=14
RSI_PERIOD=14
MAX_NORMALIZED_SMA_SLOPE=0.15
MIN_TOUCH_COUNT=2
TOUCH_SEPARATION_BARS=3
TOUCH_TOLERANCE_ATR_MULTIPLE=0.30
MIN_RANGE_WIDTH_ATR_MULTIPLE=2.0
MAX_DRIFT_TO_RANGE_RATIO=0.25
ZONE_ATR_MULTIPLE=0.30
STOP_BUFFER_ATR_MULTIPLE=0.50
RECENT_BREAKOUT_LOOKBACK_BARS=3

# Historical market data provider
HISTORICAL_MARKET_DATA_PROVIDER=stooq
HISTORICAL_MARKET_DATA_API_KEY=

# Live quote provider
LIVE_QUOTE_PROVIDER=stooq
LIVE_QUOTE_API_KEY=

# Optional operational settings
DEFAULT_SCAN_LIMIT=100
LIQUIDITY_LOOKBACK_BARS=20
