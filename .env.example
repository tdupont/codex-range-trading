# Shared application settings
APP_ENV=development
APP_NAME=range-trading-screener
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/range_trading
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/range_trading
CORS_ORIGINS=http://localhost:3000

# Data ingestion / scanning
MARKET_UNIVERSE=sp500
SCAN_TIMEFRAME=1d
SCAN_LOOKBACK_DAYS=180
RANGE_LOOKBACK_DAYS=30
ADX_PERIOD=14
SMA_PERIOD=20
ATR_PERIOD=14
RSI_PERIOD=14
MAX_SMA20_SLOPE_ABS=0.15
CONTAINMENT_THRESHOLD=0.90
MIN_TOUCH_COUNT=2
MIN_RANGE_WIDTH_ATR_MULTIPLE=1.5
ZONE_ATR_MULTIPLE=0.3
STOP_BUFFER_ATR_MULTIPLE=0.5

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Data Provider Abstraction
# Replace these placeholders when a provider is selected.
MARKET_DATA_PROVIDER=placeholder
MARKET_DATA_API_KEY=replace_me

