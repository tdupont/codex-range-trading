# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///backend/app.db
ALEMBIC_DATABASE_URL=sqlite:///backend/app.db
CORS_ORIGINS=http://localhost:3000

# Data ingestion / scanning
MARKET_UNIVERSE=sp500
SCAN_TIMEFRAME=1d
SCAN_LOOKBACK_DAYS=180
RANGE_LOOKBACK_DAYS=30
ADX_PERIOD=14
SMA_PERIOD=20
ATR_PERIOD=14
RSI_PERIOD=14
MAX_SMA20_SLOPE_ABS=0.15
CONTAINMENT_THRESHOLD=0.90
MIN_TOUCH_COUNT=2
MIN_RANGE_WIDTH_ATR_MULTIPLE=1.5
ZONE_ATR_MULTIPLE=0.3
STOP_BUFFER_ATR_MULTIPLE=0.5
TOUCH_COOLDOWN_DAYS=3

# Data provider
MARKET_DATA_PROVIDER=stooq
MARKET_DATA_API_KEY=
LOCAL_UNIVERSE_PATH=backend/data/sp500_seed.csv

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
